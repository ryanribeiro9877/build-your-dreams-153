# Frontend (Vite)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key

# Cloudflare Turnstile (captcha em /definir-senha)
# Chaves de teste (sempre passam): https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Edge Functions — copie para supabase/.env.local (UTF-8 sem BOM)
# Em produção: node scripts/set-edge-secrets.mjs (após supabase login)
# Nota: SUPABASE_URL, SUPABASE_ANON_KEY e SUPABASE_SERVICE_ROLE_KEY sao injetados
# automaticamente no runtime das Edge Functions — nao precisam ser definidos aqui.
RESEND_API_KEY=re_sua_chave_aqui
INVITE_EMAIL_FROM=JurisAI <onboarding@resend.dev>
INVITE_EMAIL_REPLY_TO=contato@seudominio.com.br
SITE_URL=http://localhost:8080
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# CORS das Edge Functions: origem permitida em producao.
# localhost:8080 e localhost:5173 ja sao aceitos automaticamente em dev.
ALLOWED_ORIGIN=https://build-your-dreams-153.vercel.app

# Sentry (error monitoring)
# DSN válida do projeto Sentry. Se estiver inválida/recusada, o SDK toma 403 no
# ingest e polui o console — rotacione a DSN OU desligue via VITE_SENTRY_ENABLED.
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Kill-switch: defina como "false" para DESLIGAR o Sentry sem remover a DSN
# (ex.: enquanto a DSN não é rotacionada). Ausente/qualquer-outro-valor = ligado.
VITE_SENTRY_ENABLED=true

# Payments (Stripe publishable key — usado no frontend)
VITE_PAYMENTS_CLIENT_TOKEN=pk_test_sua_chave_aqui

# Supabase service role (NÃO commitar — usado por scripts e Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Chave de autenticação da API de integração externa
INTEGRATION_API_KEY=jurisai_sua_chave_aqui

# Supabase project reference (used by scripts)
SUPABASE_PROJECT_ID=your-project-ref-here

# Admin seed user (used by scripts/create-admin-user.mjs)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
