# Frontend (Vite)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-anon-key

# Cloudflare Turnstile (captcha em /definir-senha)
# Chaves de teste (sempre passam): https://developers.cloudflare.com/turnstile/troubleshooting/testing/
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Edge Functions — copie para supabase/.env.local (UTF-8 sem BOM)
# Em produção: node scripts/set-edge-secrets.mjs (após supabase login)
RESEND_API_KEY=re_sua_chave_aqui
INVITE_EMAIL_FROM=JurisAI <onboarding@resend.dev>
INVITE_EMAIL_REPLY_TO=contato@seudominio.com.br
SITE_URL=http://localhost:8080
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Sentry (error monitoring)
VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Payments (Stripe publishable key — usado no frontend)
VITE_PAYMENTS_CLIENT_TOKEN=pk_test_sua_chave_aqui

# Supabase service role (NÃO commitar — usado por scripts e Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Chave de autenticação da API de integração externa
INTEGRATION_API_KEY=jurisai_sua_chave_aqui
